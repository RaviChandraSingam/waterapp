# WaterApp Backend — Environment Variables
# Copy this file to .env and fill in the values.
# backend/.env is gitignored, so secrets are never committed.

# ──────────────────────────────────────────────
# Local development (Docker)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://waterapp:waterapp_secret@localhost:5432/waterapp

# ──────────────────────────────────────────────
# Production (Supabase pooler URL)
# Get this from: Supabase Dashboard → Project → Settings → Database → Connection Pooling
# ──────────────────────────────────────────────
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres

# ──────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────
# Change this to a long random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=waterapp_jwt_secret_change_in_production

# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=3000
